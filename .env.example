# ===================================================
# HTML to Image Converter v2.0.0 - Configuração
# ===================================================
# Copie este arquivo para .env e preencha suas chaves.
# Apenas GEMINI_API_KEY é obrigatória para uso com API.
# Para uso 100% local (Ollama), nenhuma chave é necessária.

# ----- GOOGLE GEMINI (Texto + Imagem) -----
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_aqui

# ----- OLLAMA (IA Local - Gratuito) -----
# URL do servidor Ollama (padrão: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# ----- MODELOS DE TRADUÇÃO (Multi-Agente) -----
# Modelo Linguista: traduz os textos (padrão: gemma2:9b)
# OLLAMA_TRANSLATE_MODEL=gemma2:9b

# Modelo Engenheiro: reconstrói tags HTML nas traduções (padrão: qwen2.5-coder:7b)
# OLLAMA_LOGIC_MODEL=qwen2.5-coder:7b

# ----- GERAÇÃO DE IMAGENS POR IA -----
# Provider: pollinations, huggingface, gemini, ou comfyui
# IMAGE_PROVIDER=pollinations

# --- Hugging Face (Serverless API - Gratuito) ---
# Obtenha em: https://huggingface.co/settings/tokens
# HF_API_KEY=hf_sua_chave_aqui
# HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# --- Pollinations.ai (Hub Aberto) ---
# A chave é opcional (acelera a fila e reduz filtros).
# POLLINATIONS_API_KEY=sk_sua_chave_aqui
# POLLINATIONS_MODEL=flux

# URL do servidor ComfyUI (apenas se IMAGE_PROVIDER=comfyui)
# COMFYUI_URL=http://127.0.0.1:8188

# ----- OPENAI (Opcional) -----
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
